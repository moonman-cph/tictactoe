# .env.example — copy to .env and fill in values
# .env is git-ignored; .env.example is committed as a template

NODE_ENV=development
PORT=3000

# M2: PostgreSQL connection (not used in M1)
# DATABASE_URL=postgresql://user:password@localhost:5432/orgchart

# M3: JWT secret for session tokens — generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# JWT_SECRET=

# M3: Bootstrap credentials for the first super_admin user.
# Only used if no users exist in the database. Remove after first login.
# ADMIN_EMAIL=admin@yourcompany.com
# ADMIN_PASSWORD=

# M2: AES-256-GCM encryption key for sensitive fields (salary, employeeId, dateOfBirth, salary bands)
# Must be a 64-character hex string (32 bytes). Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Set this in Azure App Service Application Settings for production — never commit a real key.
# ENCRYPTION_KEY=

# M6: AI Assistant — set in Azure App Service Application Settings for production
# ANTHROPIC_API_KEY=
